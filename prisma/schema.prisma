generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model Intern {
  id String @id @default(uuid()) @map("ID")

  user_name  String
  user_email String
  user_phone String

  next_shift_ID String?
  next_shift    Scheduled_day? @relation("next_shift", fields: [next_shift_ID], references: [id])

  site_manager_ID String?
  site_manager    Site_Manager? @relation(fields: [site_manager_ID], references: [id])

  attendance_history Attendance[]
}

model Site_Manager {
  id String @id @default(uuid())

  name  String
  email String

  locations Location[]
  interns  Intern[]
}

model Location {
  id String @id @default(uuid())

  location_name String
  address       String

  attendance_code String?
  code_expires_at DateTime?

  managers Site_Manager[]
  scheduled_days Scheduled_day[]
}

model Scheduled_day {
  id String @id @default(uuid())

  start_time DateTime
  end_time   DateTime

  site_ID String
  location Location @relation(fields: [site_ID], references: [id])

  attendance Attendance[]

  next_shift_for Intern[] @relation("next_shift")
}

model Attendance {
  id String @id @default(uuid())

  clock_in_time  DateTime?
  clock_out_time DateTime?
  status         Attendance_status @default(ABSENT)

  internID String
  intern   Intern @relation(fields: [internID], references: [id])

  shift_ID String
  scheduled_day Scheduled_day @relation(fields: [shift_ID], references: [id])

  shift_request_ID String?
  shift_request    Shift_Request? @relation(fields: [shift_request_ID], references: [id])
}

model Shift_Request {
  id String @id @default(uuid())

  reason    String?
  createdAt DateTime @default(now())

  attendances Attendance[]
}

model Admin {
  id String @id @default(uuid())

  name  String
  email String
}

enum Attendance_status {
  ABSENT
  PRESENT
  CALLED_OFF
  COVERING_SHIFT
}