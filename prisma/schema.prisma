generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model User {
  ID String @id @default(uuid()) @map("ID")

  user_name  String
  user_email String
  user_phone String

  intern       Intern?
  site_manager Site_Manager?

  attendance_history Attendance[]
  schedule           Scheduled_day[]

  works_At String
  location Location @relation("interns", fields: [works_At], references: [location_ID])

  shift_requests_created Shift_Request[] @relation("created_by")
}

model Intern {
  Intern_ID String @id @map("ID")
  User      User   @relation(fields: [Intern_ID], references: [ID], onDelete: Cascade, onUpdate: Cascade)

  manager_ID String? @unique
  manager    Site_Manager? @relation(fields: [manager_ID], references: [manager_ID])

  picked_requests Shift_Request[]
}

model Site_Manager {
  manager_ID String @id @map("ID")
  User       User   @relation(fields: [manager_ID], references: [ID], onDelete: Cascade, onUpdate: Cascade)

  locations Location[]

  intern Intern?
}

model Location {
  location_ID String @id @default(uuid())

  location_name String
  address       String

  operation_days Work_day
  open_time      Int
  close_time     Int

  attendance_code String

  interns User[] @relation("interns")

  managers Site_Manager[]

  site Scheduled_day[]
}

model Attendance {
  id String @id @default(uuid())

  clock_in_time  DateTime?
  clock_out_time DateTime?
  status         Attendance_status @default(ABSENT)

  request_status Leave_request? @default(PENDING)
  reason         String?

  userID String
  User   User @relation(fields: [userID], references: [ID])
}

model Scheduled_day {
  shift_ID String @id @default(uuid())

  date DateTime
  shift_duration Int

  site_ID String
  site Location @relation(fields: [site_ID], references: [location_ID])

  status Shift_type @default(on_site)

  userID String
  User   User @relation(fields: [userID], references: [ID])

  shift_requests Shift_Request[]
}

model Shift_Request {
  id String @id @default(uuid())

  reason    String?
  createdAt DateTime @default(now())

  created_by_ID String
  created_by    User @relation("created_by", fields: [created_by_ID], references: [ID])

  picked_by_ID String?
  picked_by    Intern? @relation(fields: [picked_by_ID], references: [Intern_ID])

  shift_ID String
  shift    Scheduled_day @relation(fields: [shift_ID], references: [shift_ID])
}

enum Attendance_status {
  ABSENT
  PRESENT
  CALLED_OFF
  COVERING_SHIFT
}

enum Leave_request {
  PENDING
  ACCEPTED
  REJECTED
}

enum Shift_type {
  remote
  office_hours
  on_site
}

enum Work_day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}