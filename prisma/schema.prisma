generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model User {
  ID                 String          @id @default(uuid()) @map("ID")
  user_name          String
  user_email         String
  user_phone         String
  works_At           String

  attendance_history Attendance[]
  intern             Intern?
  schedule           Scheduled_day[]
  site_manager       Site_Manager? @relation("ManagerUser")

  location           Location        @relation("interns", fields: [works_At], references: [location_ID])
}

model Intern {
  Intern_ID String @id @map("ID")
  User      User   @relation(fields: [Intern_ID], references: [ID], onDelete: Cascade)
}

model Site_Manager {
  manager_ID String @id @map("ID")

  user       User     @relation("ManagerUser", fields: [manager_ID], references: [ID], onDelete: Cascade)

  locationID String
  location   Location @relation("ManagerLocation", fields: [locationID], references: [location_ID])
}

model Location {
  location_ID       String          @id @default(uuid())
  location_name     String
  address           String

  operation_days    Work_day
  open_time         Int
  close_time        Int

  attendance_code   String
  code_generated_at DateTime?

  site              Scheduled_day[]
  site_managers     Site_Manager[]  @relation("ManagerLocation")
  interns           User[]          @relation("interns")
}

model Attendance {
  id             String            @id @default(uuid())

  clock_in_time  DateTime?
  clock_out_time DateTime?

  status         Attendance_status @default(ABSENT)
  request_status Leave_request?    @default(PENDING)

  reason         String?

  userID         String
  User           User              @relation(fields: [userID], references: [ID])
}

model Scheduled_day {
  shift_ID       String     @id @default(uuid())

  date           DateTime
  shift_duration Int

  site_ID        String
  status         Shift_type @default(on_site)

  userID         String

  User           User       @relation(fields: [userID], references: [ID])
  site           Location   @relation(fields: [site_ID], references: [location_ID])
}

enum Attendance_status {
  ABSENT
  PRESENT
  CALLED_OFF
  COVERING_SHIFT
}

enum Leave_request {
  PENDING
  ACCEPTED
  REJECTED
}

enum Shift_type {
  remote
  office_hours
  on_site
}

enum Work_day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
