generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}


// Renamed User to Intern
model Intern {
  ID            String   @id @default(uuid())
  user_name     String
  user_email    String   @unique
  user_phone    String?

  // Removed works_At and location

  // Next upcoming shift pointer
  next_shift_ID String?
  next_shift    Scheduled_day? @relation("next_shift", fields: [next_shift_ID], references: [shift_ID])

  // Optional Site Manager relation
  site_manager_ID String?
  site_manager Site_Manager? @relation(fields: [site_manager_ID], references: [manager_ID])

  attendance_history Attendance[]
}

// UPDATED Site Manager
model Site_Manager {
  manager_ID String   @id @default(uuid())
  name       String
  email      String   @unique

  // Changed to list of locations
  locations  Location[]
  interns Intern[]
}

// UPDATED Location
model Location {
  location_ID    String   @id @default(uuid()) //location identifier
  //location information name contact days used and times
  location_name  String   //@unique
  address        String   
  operation_days Work_day
  open_time      Int
  close_time     Int

  //generated code to check attendance at a location during a workday
  attendance_code String

  //list of interns and site manager of specific location
  //userId  String        @unique
  interns User[]        @relation("interns")
  manager Site_Manager? @relation("manager")

  site     Scheduled_day[] 
}

//1 to many user has many attendances,
model Attendance {
  id String @id @default(uuid()) //unique identifier

  //clock in time and out time and current attendance status
  clock_in_time  DateTime?
  clock_out_time DateTime?
  status         Attendance_status @default(ABSENT) //defualt being absent

  //absence requests including the status, reason(optional), and covering intern(optional)
  request_status Leave_request? @default(PENDING)
  reason         String?

  //id and relationship to the user
  userID String
  User   User   @relation(fields: [userID], references: [ID])
}

model Scheduled_day {
  // shift identifier
  shift_ID String @id @default(uuid())

  // shift start time (date + time)
  date DateTime

  // duration of shift in minutes
  shift_duration Int

  // location where shift occurs
  site_ID String
  site Location @relation(fields: [site_ID], references: [location_ID])

  // shift type
  status Shift_type @default(on_site)

  // relationship with user
  userID String
  User   User @relation(fields: [userID], references: [ID])
}

//the below are enums that are used to signify status's
enum Attendance_status {
  ABSENT //If the intern is absent
  PRESENT //if the intern is actively present
  CALLED_OFF //if the intern had called off in advance   
  //EXCUSED           //excused abscence doctors note etc
  COVERING_SHIFT //for a intern covering a shift of another intern
}

enum Leave_request {
  PENDING
  ACCEPTED
  REJECTED
}

enum Shift_type {
  remote
  office_hours
  on_site
}

enum Work_day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
