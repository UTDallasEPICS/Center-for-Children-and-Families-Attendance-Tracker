// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id String @id @default(uuid()) @map("ID")

  user_name  String
  user_email String
  user_phone String

  intern       Intern?
  site_manager Site_Manager?

  attendance_history Attendance[]
  schedule           Scheduled_day[]

  works_At String
  location Location @relation("interns", fields: [works_At], references: [id])
}

model Intern {
  id   String @id @map("ID")
  user User   @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Site_Manager {
  id   String @id @map("ID")
  user User   @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Location {
  id String @id @default(uuid())

  location_name String
  address       String

  operation_days Work_day
  open_time      Int
  close_time     Int

  attendance_code String

  interns User[] @relation("interns")

  scheduled_days Scheduled_day[]
}

model Attendance {
  id String @id @default(uuid())

  clock_in_time  DateTime?
  clock_out_time DateTime?
  status         Attendance_status @default(ABSENT)

  reason String?

  userID String
  user   User @relation(fields: [userID], references: [id])

  shift_request Shift_Request?
}

model Shift_Request {
  id String @id @default(uuid())

  reason    String?
  createdAt DateTime @default(now())

  attendanceId String @unique
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
}

model Scheduled_day {
  id String @id @default(uuid())

  date           DateTime
  shift_duration Int

  site_ID String
  site    Location @relation(fields: [site_ID], references: [id])

  status Shift_type @default(on_site)

  userID String
  user   User @relation(fields: [userID], references: [id])
}

enum Attendance_status {
  ABSENT
  PRESENT
  CALLED_OFF
  COVERING_SHIFT
}

enum Leave_request {
  PENDING
  ACCEPTED
  REJECTED
}

enum Shift_type {
  remote
  office_hours
  on_site
}

enum Work_day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}