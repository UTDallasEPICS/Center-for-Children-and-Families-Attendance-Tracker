generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}


// Renamed User to Intern
model Intern {
  ID            String   @id @default(uuid())
  user_name     String
  user_email    String   @unique
  user_phone    String?

  // Removed works_At and location

  // Next upcoming shift pointer
  next_shift_ID String?
  next_shift    Scheduled_day? @relation("next_shift", fields: [next_shift_ID], references: [shift_ID])

  // Optional Site Manager relation
  site_manager_ID String?
  site_manager Site_Manager? @relation(fields: [site_manager_ID], references: [manager_ID])

  attendance_history Attendance[]
}

// UPDATED Site Manager
model Site_Manager {
  manager_ID String   @id @default(uuid())
  name       String
  email      String   @unique

  // Changed to list of locations
  locations  Location[]
  interns Intern[]
}

// UPDATED Location
model Location {
  location_ID String   @id @default(uuid())
  name        String

  attendance_code String?

  // single datetime
  code_expires_at DateTime?

  managers Site_Manager[]
  scheduled_days Scheduled_day[]
}

// UPDATED Scheduled_day
model Scheduled_day {
  shift_ID   String   @id @default(uuid())

  // Replaced date and duration
  start_time DateTime
  end_time   DateTime

  site_ID    String
  location   Location @relation(fields: [site_ID], references: [location_ID])

  // Removed userID

  attendance Attendance[]

  next_shift_for Intern[] @relation("next_shift")
}

// UPDATED Attendance
model Attendance {
  id              String   @id @default(uuid())

  clock_in_time   DateTime?
  clock_out_time  DateTime?

  status          String

  // added relation to Scheduled_day
  shift_ID        String
  scheduled_day   Scheduled_day @relation(fields: [shift_ID], references: [shift_ID])

  internID        String
  intern          Intern @relation(fields: [internID], references: [ID])

  // Replaced request_status with relation
  shift_request_ID String?
  shift_request    Shift_Request? @relation(fields: [shift_request_ID], references: [id])
}

// Added Admin Table
model Admin {
  id    String @id @default(uuid())
  name  String
  email String @unique
}

// Added Shift Request Table (minimal)
model Shift_Request {
  id        String   @id @default(uuid())
  reason    String?
  createdAt DateTime @default(now())
  attendances Attendance[]
}